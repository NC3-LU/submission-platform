# -------------------------------------------------------
# Docker Compose Environment Variables
# -------------------------------------------------------
# Copy this file to .env (or docker-compose.env) and fill
# in the values before running: docker compose up -d
# -------------------------------------------------------

# Database Configuration
DB_DATABASE=submission_platform
DB_USERNAME=app_user
DB_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root_secret

# Application Configuration
APP_NAME="NC3 Submission Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=en

# Security
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# Session & Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

# Mail Configuration
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# Frontend
VITE_APP_NAME="NC3 Submission Platform"

# API Documentation
API_DOCS_ALLOWED_DOMAINS=

# Pandora File Scanning (optional - activate with COMPOSE_PROFILES=pandora)
PANDORA_ENABLED=false
PANDORA_URL=http://pandora:6100
PANDORA_TIMEOUT=30
PANDORA_POLL_INTERVAL=2
PANDORA_BLOCK_MALICIOUS=true

# Proxy (leave empty if not behind a proxy)
PROXY=
